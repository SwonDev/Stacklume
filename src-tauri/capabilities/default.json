{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capabilities/schema.json",
  "identifier": "default",
  "description": "Capacidades predeterminadas de Stacklume desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "single-instance:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-open",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart",
    "window-state:allow-restore",
    "window-state:allow-save-window-state",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all"
  ]
}
