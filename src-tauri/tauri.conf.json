{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stacklume",
  "version": "0.3.17",
  "identifier": "com.stacklume.app",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri",
    "devUrl": "http://localhost:7878",
    "beforeBuildCommand": "pnpm build:desktop",
    "frontendDist": "../dist-placeholder"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Stacklume",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "visible": false,
        "url": "about:blank"
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4RDJDMkUzQzExMjY1OEUKUldTT1pSTEI0OExTV05wLzFhWkk4dWoxc2dDOXljcCt2aW1TdGN5NXdQUS9aaEg5VFJZUGt4THgK",
      "endpoints": [
        "https://github.com/SwonDev/Stacklume/releases/latest/download/update-manifest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/**/*"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": [
          "Spanish"
        ],
        "startMenuFolder": "Stacklume",
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  }
}
