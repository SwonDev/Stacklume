{
  "manifest_version": 3,
  "name": "Stacklume — Guarda enlaces",
  "version": "1.1.0",
  "description": "Guarda el enlace actual en Stacklume con un solo clic. Compatible con la app de escritorio y cualquier instancia propia.",
  "homepage_url": "https://github.com/SwonDev/Stacklume",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Guardar en Stacklume"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Abrir Stacklume para guardar el enlace actual"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "stacklume@swondev.com",
      "strict_min_version": "109.0"
    }
  }
}
