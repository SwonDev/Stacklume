# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build
/dist
/dist-extension

# misc
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - NEVER commit these!
.env
.env.local
.env.*.local
.env*.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry
.sentryclirc

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Cache
.cache/
.turbo/

# Windows reserved names
nul
NUL

# Tauri — artefactos de build generados (no commitear)
src-tauri/target/
src-tauri/resources/node/
src-tauri/resources/server/
src-tauri/resources/llama/
src-tauri/gen/

# Next.js standalone build para desktop (generado por build-desktop.mjs)
dist-placeholder/*.html
!dist-placeholder/index.html

# Archivos temporales y accidentales
tmp/
null
*.db
*.db-shm
*.db-wal

# Lint output files (dev only)
lint_*.txt

# Documentación interna (no relevante para usuarios externos)
docs/
src/lib/API_CLIENT_GUIDE.md
src/stores/WIDGET_STORE_GUIDE.md

# Artefactos de desarrollo interno (scripts auxiliares)
scripts/i18n-keys-*.json
scripts/take-screenshots.mjs
scripts/screenshot-demo.mjs

# Claude Code — configuración local privada
.claude/
CLAUDE.md

# AI tools config — instrucciones internas para asistentes de código
AGENTS.md

# Tests — no se publican en el repo público
e2e/
src/test/
src/**/__tests__/
src/**/*.test.ts
src/**/*.test.tsx
src/**/*.spec.ts
src/**/*.spec.tsx
vitest.config.ts
playwright.config.ts
playwright.extension.config.ts
/coverage/
/playwright-report/
/playwright-report-extension/
/playwright-report-stickers/
/playwright-results/
/playwright-results-extension/
/playwright-extension-profile*/
/test-results/
/test-screenshots/

# Extensión del navegador (repo y distribución separados)
/extension/
/dist-extension/
/assets/extension/
/assets/extension-en/

# Componentes solo para la web (no forman parte de la app)
/src/components/kokonutui/

# Proyectos independientes que viven en este directorio
/stacklume-web/
