# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/playwright-results
/test-results

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - NEVER commit these!
.env
.env.local
.env.*.local
.env.development
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry
.sentryclirc

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Cache
.cache/
.turbo/

# Windows reserved names
nul
NUL

# Tauri — artefactos de build generados (no commitear)
src-tauri/target/
src-tauri/resources/node/
src-tauri/resources/server/
src-tauri/gen/

# Next.js standalone build para desktop (generado por build-desktop.mjs)
dist-placeholder/*.html
!dist-placeholder/index.html

# Archivos temporales y accidentales
tmp/
null
*.db
*.db-shm
*.db-wal

# Lint output files (dev only)
lint_*.txt

